# ----------------------------
# Text files (normalize line endings)
# ----------------------------
# Code files
*.c       text eol=lf
*.cpp     text eol=lf
*.h       text eol=lf
*.cs      text eol=lf
*.java    text eol=lf
*.py      text eol=lf
*.rb      text eol=lf
*.go      text eol=lf
*.rs      text eol=lf
*.php     text eol=lf

# Scripts / markup
*.js      text eol=lf
*.ts      text eol=lf
*.jsx     text eol=lf
*.tsx     text eol=lf
*.json    text eol=lf
*.html    text eol=lf
*.css     text eol=lf
*.scss    text eol=lf
*.md      text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.sh      text eol=lf
*.bat     text eol=crlf

# ----------------------------
# Binary files (do NOT normalize)
# ----------------------------
# Fonts
*.ttf     binary
*.otf     binary
*.woff    binary
*.woff2   binary

# Images
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.svg     binary

# Documents / archives
*.pdf     binary
*.zip     binary
*.tar     binary
*.gz      binary
*.rar     binary
*.7z      binary

# Audio / Video
*.mp3     binary
*.wav     binary
*.mp4     binary
*.mov     binary

# ----------------------------
# Optional: auto-detect remaining text files
# ----------------------------
* text=auto
